# Copy to .env and fill in if you need a proxy (e.g. YouTube is blocked / your IP
# is rate-limited). Leave empty to connect to YouTube directly.
#
# Supported schemes: socks://, socks5://, socks5h://, http://, https://
# "socks://" is automatically upgraded to "socks5h://" (DNS resolved on the proxy).
YT_PROXY=

# Example:
# YT_PROXY=socks://user:pass@host:1080
