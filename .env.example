# Copy to .env and adjust as needed. Every value here is optional — the defaults
# reproduce the built-in behaviour, so an empty .env works fine.

# ----------------------------------------------------------------------------
# Network: proxy + cookies (only needed where YouTube is blocked / gated)
# ----------------------------------------------------------------------------
# Supported schemes: socks://, socks5://, socks5h://, http://, https://
# "socks://" is automatically upgraded to "socks5h://" (DNS resolved on proxy).
YT_PROXY=
# Example:
# YT_PROXY=socks://user:pass@host:1080

# Path (inside the container) to a Netscape cookies.txt with a YouTube session.
YT_COOKIES=/data/cookies.txt

# ----------------------------------------------------------------------------
# Server
# ----------------------------------------------------------------------------
# PORT=8080               # HTTP port
# YTDLP_UPDATE=1          # pull the latest yt-dlp on container start (entrypoint)
# MAX_UPLOAD_MB=64        # request-body cap (guards against huge cover uploads)
# DEFAULT_MODE=mp3        # mp3 | audio | video — used when the UI omits it
# DEFAULT_QUALITY=best    # best|2160|1440|1080|720|480|360 (video mode)

# ----------------------------------------------------------------------------
# MP3 / cover encoding
# ----------------------------------------------------------------------------
# MP3_BITRATE=320k        # libmp3lame target bitrate (e.g. 192k, 256k, 320k)
# COVER_MAX_PX=1200       # longest edge of the embedded cover, downscaled if bigger
# COVER_QUALITY=5         # ffmpeg JPEG -q:v, 2=best .. 31=worst

# ----------------------------------------------------------------------------
# yt-dlp behaviour
# ----------------------------------------------------------------------------
# YTDLP_RETRIES=10              # retries for both whole-file and fragments
# YTDLP_CONCURRENT_FRAGMENTS=4  # parallel fragment downloads
# YTDLP_USE_EJS=1               # 0 disables the GitHub EJS challenge solver

# ----------------------------------------------------------------------------
# Timeouts & cleanup (seconds)
# ----------------------------------------------------------------------------
# INFO_TIMEOUT=180        # max time for the preview/info fetch
# REAP_INTERVAL=120       # how often the cleanup sweep runs
# JOB_TTL=300             # delete a finished job's files this long after completion
# ORPHAN_TTL=3600         # delete stray temp dirs older than this
